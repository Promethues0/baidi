            ]
          }
        },
        {
          "title": "令牌签发（ZL-FR-504/505）",
          "body": {
            "kind": "rows",
            "items": [
              { "main": "默认签名", "sub": "EdDSA (Ed25519) · DP-14", "badge": { "tone": "ok", "text": "启用" } },
              { "main": "国密双轨", "sub": "SM2 签名套件 · 信创随策略下发", "right": "关" },
              { "main": "JWKS 轮换", "sub": "kid 轮换 · 旧 key 宽限 7 天", "right": "上次 2026-06-03" }
            ]
          }
        },
        {
          "title": "账号保护（REQ-SEC-012/013）",
          "body": {
            "kind": "rows",
            "items": [
              { "main": "失败锁定", "sub": "连续失败锁定账户", "right": "5 次 / 锁 15 分钟" },
              { "main": "密码强度", "sub": "argon2 存储 · 复杂度策略", "right": "≥10 位 · 4 类取 3" },
              { "main": "API Token", "sub": "仅创建时展示一次", "badge": { "tone": "ok", "text": "已生效" } }
            ]
          }
        }
      ]
    }
  ]
