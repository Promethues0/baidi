# 复制为 config.env 并填写后用于 deploy.sh（config.env 已 gitignore）

# ── 场景 A：独占整机（推荐，101.43.125.131 铲除原业务后独占）──
SERVER_SSH=root@101.43.125.131
SSH_KEY=~/.ssh/id_ed25519
PUBLIC_HOST=101.43.125.131
BD_HTTPS_PORT=443            # 独占机用标准 443；安全组放行 443
WIPE=1                       # deploy.sh 部署前先铲除原业务（停服务+备份 nginx+释放 80/443）

# ── 场景 B：与烛龙共存（124.223.225.77）── 改用下面三行：
# SERVER_SSH=ubuntu@124.223.225.77
# SSH_KEY=~/.ssh/zhulong_tongsuo
# PUBLIC_HOST=124.223.225.77
# BD_HTTPS_PORT=9443         # 共存机用独立端口，绝不碰烛龙 80/443

# 安装前缀 / 运行用户 / 控制中心内部端口（回环）/ CORS 来源
BD_PREFIX=/opt/baidi
BD_USER=baidi
CONTROL_PORT=8090
PUBLIC_ORIGIN=*
