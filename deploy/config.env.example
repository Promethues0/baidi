# 复制为 config.env 并填写后用于 deploy.sh（config.env 已 gitignore）
# 目标服务器 SSH。注意：该机已部署烛龙 IPSEC 网关，root 登录不通；
# 用烛龙部署用户 ubuntu + 其私钥（passwordless sudo）。
SERVER_SSH=ubuntu@124.223.225.77
SSH_KEY=~/.ssh/zhulong_tongsuo
PUBLIC_HOST=124.223.225.77

# 白帝独立 HTTPS 端口（绝不碰烛龙的 80/443，需在腾讯云安全组放行）
BD_HTTPS_PORT=9443

# 安装前缀 / 运行用户 / 控制中心内部端口（回环）/ CORS 来源
BD_PREFIX=/opt/baidi
BD_USER=baidi
CONTROL_PORT=8090
PUBLIC_ORIGIN=*
