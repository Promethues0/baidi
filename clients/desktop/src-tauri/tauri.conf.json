{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "白帝安全接入客户端",
  "version": "0.1.0",
  "identifier": "dev.baidi.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5294",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "白帝安全接入客户端",
        "width": 1040,
        "height": 700,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/baidi-knock", "binaries/baidi-tun"]
  }
}
